5.
a)
  Keeps data organized in files and folders.
  Makes storing, reading, and updating easy.
  Protects data with permissions and avoids loss.
b)open() → Connects a file to the program, returns a file descriptor for operations.
  close() → Ends the connection, saves changes, and frees resources.
c)
#include <stdio.h>
#include <fcntl.h>   
#include <unistd.h>  
int main() {
    int fd;
    char buffer[100];
    int count
    fd = open("students.txt", O_RDONLY);
    if (fd < 0) {
        printf("Error opening file\n");
        return 1;
    }
    count = read(fd, buffer, sizeof(buffer)-1);
    buffer[count] = '\0';   // null terminate
    printf("File contents: %s\n", buffer);
    close(fd);
    return 0;
}
